# Copy to .env.local and fill in from your Auth0 application (SPA type).
# In the Auth0 application settings, add these URLs:
#   Allowed Callback URLs:        http://localhost:5173/auth/callback
#   Allowed Logout URLs:          http://localhost:5173
#   Allowed Web Origins:          http://localhost:5173

# Auth0 domain WITH a trailing slash (custom domains also work).
VITE_OIDC_AUTHORITY=https://YOUR_TENANT.auth0.com/
VITE_OIDC_CLIENT_ID=
# Optional; defaults to "openid profile email". Add "offline_access" for refresh-token renewal.
VITE_OIDC_SCOPE=openid profile email
